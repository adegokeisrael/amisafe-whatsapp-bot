# Meta WhatsApp Cloud API
WHATSAPP_TOKEN=your_whatsapp_cloud_api_bearer_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_API_VERSION=v19.0

# Webhook verification
VERIFY_TOKEN=any_random_string_you_choose

# Encryption key — generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite:///./amisafe.db
# DATABASE_URL=postgresql://user:password@localhost:5432/amisafe

# Partner dashboard access
PARTNER_API_KEY=a_long_random_key_for_partner_api_access

# Media temp storage path
MEDIA_TEMP_DIR=/tmp/amisafe_media

# Session TTL in seconds (default: 30 minutes)
SESSION_TTL=1800

# Logging
LOG_LEVEL=INFO
